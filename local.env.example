export BACKEND_VERSION=resolve_prod
export EDGE_VERSION=resolve_prod
export FRONTEND_VERSION=resolve_prod
export LOCAL_TEST_COMMAND='pnpm exec jest ./tests/general/'

# Optional: override isolated host ports if one is already in use.
# export MYSQL_APP_DB_2_PORT=13317

# Optional: Edge runtime investigation.
# Local platform defaults to Cranelift-only compilation for faster disposable
# runs. Opt into LLVM package engine filters only when validating prod-equivalent
# compilation behavior.
# export LOCAL_PLATFORM_EDGE_ENABLE_LLVM=1
# export WASMER_TEST_FETCH_TIMEOUT_MS=60000
# export LOCAL_PLATFORM_KEEP_RUNNING_ON_FAILURE=1

# Optional: package dependency seeding.
# make local-test mirrors discovered test package dependencies from the public
# registry into the disposable local registry before Edge/tests start.
# export LOCAL_PLATFORM_SEED_PACKAGES=1
# export LOCAL_PLATFORM_PACKAGE_SOURCE_REGISTRY=https://registry.wasmer.io/graphql
# export LOCAL_PLATFORM_PACKAGE_SEED_FILE=local-platform/package-seed.txt
# export LOCAL_PLATFORM_PACKAGE_DIRECT_REF_NAMESPACE_ALLOWLIST=wasmer
